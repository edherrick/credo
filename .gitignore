alembic/versions/__pycache__/

# ── Testing / coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Node / SvelteKit ──────────────────────────────────────────────────────────
node_modules/
.svelte-kit/
.output/
build/

# ── Editor & OS ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Docker ────────────────────────────────────────────────────────────────────
# docker-compose.override.yml is typically local-only
docker-compose.override.yml
